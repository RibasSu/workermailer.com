{
	"name": "workermailer",
	"account_id": "25e789adb7024710a1011d917a812ff1",
	"compatibility_date": "2026-04-07",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"workers_dev": true,
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"invocation_logs": true,
			"persist": true
		},
		"traces": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true
		}
	},
	"routes": [
		{
			"pattern": "workermailer.com",
			"custom_domain": true
		},
		{
			"pattern": "www.workermailer.com",
			"custom_domain": true
		}
	],
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	}
}
