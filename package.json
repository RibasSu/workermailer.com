{
  "name": "worker-mailer-site",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bunx vite dev",
    "build": "bunx vite build",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "deploy": "bun run build && wrangler deploy",
    "prepare": "bun --bun svelte-kit sync || echo ''",
    "check": "bun --bun svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun --bun svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "gen": "wrangler types"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "flowbite": "^4.0.1",
    "flowbite-svelte": "^1.33.1",
    "flowbite-svelte-icons": "^3.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "wrangler": "^4.81.1"
  }
}
